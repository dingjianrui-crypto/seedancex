# Environment
DATABASE_URL="postgresql://user:password@host:port/dbname"
DIRECT_URL="postgresql://user:password@host:port/dbname"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your_nextauth_secret_here"

# Google Auth (for login)
GOOGLE_CLIENT_ID="your_google_id_here"
GOOGLE_CLIENT_SECRET="your_google_secret_here"

# Seedance V2 API (for image/video logic)
ARK_API_KEY="your_ark_or_seedance_key_here"
SEEDANCE_ENDPOINT="volcano engine or byteplus seedance endpoint here"
SEEDANCE_MODEL="dreamina-seedance-2-0-260128"
SEEDANCE_FAST_MODEL="dreamina-seedance-2-0-fast-260128"
WEBHOOK_URL="your_webhook_url"
CREDIT_PROFIT_FACTOR="1.2"

# Vercel Blob
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Volcengine trusted asset library
VOLCENGINE_ACCESS_KEY_ID="your_volcengine_access_key_id"
VOLCENGINE_SECRET_ACCESS_KEY="your_volcengine_secret_access_key"
VOLCENGINE_ASSET_GROUP_ID="your_shared_asset_group_id"
VOLCENGINE_PROJECT_NAME="your project name in volcengine"

# Stripe (for payments)
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Dynamic UI Theme Configuration
# Hosted Admins: Choose between: indigo, emerald, rose, amber, violet
NEXT_PUBLIC_THEME=indigo
